@model TruongCongHuy_64130895.Models.Product

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h4>Sản phẩm</h4>
<hr />
<div class="bg-light rounded-2 p-3">
    <form asp-action="Edit" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />

        <table class="table table-bordered">
            <tbody>
                <tr>
                    <th><label asp-for="Name" class="control-label">Tên sản phẩm</label></th>
                    <td>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </td>
                </tr>
                <tr>
                    <th><label asp-for="Description" class="control-label">Mô tả</label></th>
                    <td>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </td>
                </tr>
                <tr>
                    <th><label asp-for="Price" class="control-label">Đơn giá</label></th>
                    <td>
                        <input asp-for="Price" min="0" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </td>
                </tr>
                <tr>
                    <th><label asp-for="CategoryId" class="control-label">Danh mục sản phẩm</label></th>
                    <td>
                        <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId"></select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </td>
                </tr>
                <tr>
                    <th><label asp-for="ImageUrl" class="control-label">Ảnh sản phẩm</label></th>
                    <td>
                        <input asp-for="ImageUrl" class="form-control" name="ImgUpload" type="file" />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    </td>
                </tr>
                <tr>
                    <th><label>Trạng thái</label></th>
                    <td>
                        <div class="form-check">
                            <input class="form-check-input" asp-for="IsActive" />
                            <label class="form-check-label">@Html.DisplayNameFor(model => model.IsActive)</label>
                        </div>
                    </td>
                </tr>
                <tr>
                    <th><label>Hot</label></th>
                    <td>
                        <div class="form-check">
                            <input class="form-check-input" asp-for="IsHot" />
                            <label class="form-check-label">@Html.DisplayNameFor(model => model.IsHot)</label>
                        </div>
                    </td>
                </tr>
                <tr>
                    <th><label>Sales</label></th>
                    <td>
                        <div class="form-check">
                            <input class="form-check-input" asp-for="IsOnSale" />
                            <label class="form-check-label">@Html.DisplayNameFor(model => model.IsOnSale)</label>
                        </div>
                    </td>
                </tr>
                <tr>
                    <th><label asp-for="DiscountPercent" class="control-label">Giảm giá (%)</label></th>
                    <td>
                        <input asp-for="DiscountPercent" min="0" max="100" type="number" class="form-control" />
                        <span asp-validation-for="DiscountPercent" class="text-danger"></span>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="text-center">
            <input type="submit" value="Lưu" class="btn btn-primary mx-2" />
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
