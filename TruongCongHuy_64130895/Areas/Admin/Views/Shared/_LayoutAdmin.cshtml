@using Microsoft.AspNetCore.Identity;

@inject UserManager<Customers> userManager
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>DASHMIN - Bootstrap Admin Template</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Favicon -->
    <link href="/Admin-template/img/favicon.ico" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="/Admin-template/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="/Admin-template/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />

    <!-- Customized Bootstrap Stylesheet -->
    <link href="/Admin-template/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="/Admin-template/css/style.css" rel="stylesheet">
</head>
<body>
    <div class="container-xl position-relative bg-white d-flex p-0">
        <!-- Spinner Start -->
        <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="sr-only">Loading...</span>
            </div>
        </div>
        <!-- Spinner End -->
        <!-- Sidebar Start -->
        <div class="sidebar pb-3">
            <nav class="navbar bg-light navbar-light">
                <a asp-controller="HomeAdmin" asp-action="Index" class="navbar-brand mx-4 mb-3">
                    <h3 class="text-primary"><i class="fas fa-user-tie me-2"></i>ShopAdmin</h3>
                </a>
                <div class="d-flex align-items-center ms-4 mb-4">
                    <div class="position-relative">
                        @{
                            var currentUser = await userManager.GetUserAsync(User);
                            var role = await userManager.GetRolesAsync(currentUser);
                            var roleName = role.FirstOrDefault();
                        }
                        <img class="rounded-circle" src="~/Image/Avatar/@currentUser.avatar" alt="" style="width: 40px; height: 40px;">
                        <div class="bg-success rounded-circle border border-2 border-white position-absolute end-0 bottom-0 p-1"></div>
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-0">@currentUser.UserName</h6>
                        <span>@roleName</span>
                    </div>
                </div>
                <div class="navbar-nav w-100">
                    <a asp-controller="HomeAdmin" asp-action="Index" class="nav-item nav-link"><i class="fa fa-home me-2"></i>Trang Chủ</a>
                    <a asp-controller="CategoriesAdmin" asp-action="Index" class="nav-item nav-link"><i class="fa fa-tags me-2"></i>Danh mục</a>
                    <a asp-controller="ProductsAdmin" asp-action="Index" class="nav-item nav-link"><i class="fa fa-box-open me-2"></i>Sản Phẩm</a>
                    <a asp-controller="MenuAdmin" asp-action="Index" class="nav-item nav-link"><i class="bi bi-layout-text-sidebar-reverse me-2"></i>Quản lí menu</a>
                    <a asp-controller="OrderManageAdmin" asp-action="ManageOrders" class="nav-item nav-link"><i class="fa fa-shopping-cart me-2"></i>Quản lí đơn hàng</a>
                    <a asp-controller="StatisticalAdmin" asp-action="RevenueStatistics" class="nav-item nav-link"><i class="fa fa-chart-line me-2"></i>Thống kê doanh thu</a>
                    <a asp-controller="CustomersAdmin" asp-action="Index" class="nav-item nav-link"><i class="fa fa-users me-2"></i>Khách hàng</a>
                    <a asp-controller="ReviewsAdmin" asp-action="Index" class="nav-item nav-link"><i class="fa fa-comment-dots me-2"></i>Đánh giá khách hàng</a>
                    <a asp-controller="RolesManages" asp-action="Index" class="nav-item nav-link"><i class="fa fa-user-shield me-2"></i>Quản lí quyền</a>
                    <a asp-controller="ManageUserRoles" asp-action="Index" class="nav-item nav-link"><i class="fa fa-user-tag me-2"></i>Phân quyền</a>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-item nav-link"><i class="fa fa-store me-2"></i>Quay về cửa hàng</a>
                </div>
            </nav>
        </div>
        <!-- Sidebar End -->
        <!-- Content Start -->
        <div class="content">
            <!-- Navbar Start -->
            <nav class="navbar navbar-expand bg-light navbar-light sticky-top px-4 py-0">
                <a href="index.html" class="navbar-brand d-flex d-lg-none me-4">
                    <h2 class="text-primary mb-0"><i class="fa fa-hashtag"></i></h2>
                </a>
                <a href="#" class="sidebar-toggler flex-shrink-0">
                    <i class="fa fa-bars"></i>
                </a>
                <form class="d-none d-md-flex ms-4">
                    <input class="form-control border-0" type="search" placeholder="Search">
                </form>
                @* <div class="navbar-nav align-items-center ms-auto">
                    <partial name="_LoginPartial" />
                </div> *@
            </nav>
            <!-- Navbar End -->

            <div class="container-fluid pt-4 px-4">
                @RenderBody()
            </div>

            <!-- Footer Start -->
            <div class="container-fluid pt-4 px-4">
                <div class="bg-light rounded-top p-4">
                    <div class="row">
                        <div class="col-12 col-sm-6 text-center text-sm-start">
                            &copy; 2024<br />
                            Liên hệ hỗ trợ: support@example.com
                        </div>
                        <div class="col-12 col-sm-6 text-center text-sm-end">
                            Theo dõi chúng tôi <br />
                            <a href="#"><i class="bi bi-facebook me-2"></i>Facebook</a> <br />
                            <a href="#"><i class="bi bi-instagram me-2"></i>Instagram</a> <br />
                        </div>
                    </div>
                </div>
            </div>
            <!-- Footer End -->
        </div>
        <!-- Content End -->
        <!-- Back to Top -->
        <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>
    </div>

    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/Admin-template/lib/chart/chart.min.js"></script>
    <script src="/Admin-template/lib/easing/easing.min.js"></script>
    <script src="/Admin-template/lib/waypoints/waypoints.min.js"></script>
    <script src="/Admin-template/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="/Admin-template/lib/tempusdominus/js/moment.min.js"></script>
    <script src="/Admin-template/lib/tempusdominus/js/moment-timezone.min.js"></script>
    <script src="/Admin-template/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js"></script>
    <script src="/Admin-template/js/main.js"></script>
    @RenderSection("scripts", false)
</body>
</html>
