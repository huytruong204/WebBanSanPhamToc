@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<TruongCongHuy_64130895.Models.Product>
 <!--================Home Banner Area =================-->
<!-- breadcrumb start-->
<section class="breadcrumb breadcrumb_bg">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="breadcrumb_iner">
                    <div class="breadcrumb_iner_item">
                        <h2>Danh sách sản phẩm</h2>
                        <p>Trang chủ <span>-</span>Danh sách sản phẩm</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- breadcrumb start-->

<div id="successToast" class="d-none">
    <div class="icon-check mb-3">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
    </div>

    <p class="mb-0 text-white">Sản phẩm đã được thêm vào Giỏ hàng</p>
</div>

<!--================Category Product Area =================-->
<section class="cat_product_area section_padding">
    <div class="px-xl-5">
        <div class="row px-xl-5">
            <div class="col-xl-3 px-xl-0 px-4 ">
                @await Component.InvokeAsync("DanhMucMenu")
                @await Component.InvokeAsync("SanPhamNoiBat", new { limit = 5 })
             </div>
            <div class="col-xl-9 ">
                <div>
                    <div class="row justify-content-end">
                        <form method="get" class="col-3" >
                            <select class="form-select border text-center" name="SapXep" asp-items="ViewBag.order" onchange="this.form.submit()"></select>
                        </form>
        
                        <form method="get" class="col-9">
                            <div class="input-group">
                                <input type="text" class="form-control rounded-start col-9" name="TimKiem" value="@ViewBag.TimKiem" placeholder="Nhập từ khóa để tìm sản phẩm" aria-describedby="button-addon2">
                                <button class="btn btn-outline-info col-3" style="border-radius: 0 10px 10px 0" type="Submit" id="button-addon2"><i class="bi bi-search"></i></button>
                            </div>
                        </form>

                    </div>
                </div>
                <div class="row align-items-center latest_product_inner justify-content-around">
                    @foreach (var item in Model){
                        <div class="card mb-4 " style="width: 20rem;" >
                            <a asp-action="Details" asp-route-id="@item.Id" ><img src="/Admin-template/Images/SanPham/@item.ImageUrl" class="card-img-top" style=" height:30vh;" alt=""></a>
                            <div class="card-body">
                                <h3 class="card-title">@item.Name</h3>
                                @if (item.IsOnSale)
                                {
                                     <h6 class="card-text"><del>@item.Price.ToString("#,##0 VND")</del></h6>
                                    <h3 class="card-text text-info">@item.PriceSales.GetValueOrDefault().ToString("#,##0 VND")</h3>
                                }
                                else
                                {
                                    <h3 class="card-text text-info">@item.Price.ToString("#,##0 VND")</h3>
                                }
                                <button onclick="clickAddToCart(@item.Id)" class="btn btn-info rounded-pill px-3 border py-2"> <i class="fa fa-shopping-cart"></i> &nbsp;<span>Thêm vào giỏ hàng</span> </Button>
                            </div>
                        </div>
                    }
                    <div class="col-lg-12">
                        <div class="flex-column align-items-center d-flex">
                            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, SapXep = ViewData["SapXep"], TimKiem = ViewBag.TimKiem }), new X.PagedList.Web.Common.PagedListRenderOptions
                       {
                           PageClasses = new[] { "page-link" },
                           ClassToApplyToFirstListItemInPager = "page-item",
                           ClassToApplyToLastListItemInPager = "page-item",
                       })
                        </div>

                        <style>
                            .custom-pagination {
                                margin-top: 20px;
                            }

                            .page-item {
                                margin: 0 5px;
                            }

                            .page-link {
                                background-color: #fff;
                            }

                                .page-link:hover {
                                    background-color: #f1f1f1;
                                    border-color: #ccc;
                                }
                                .page-item.active .page-link {
                                        border: none;
                                        background-color: lightskyblue; 
                                        color: none; 
                                    }
                        </style>
                    </div>
                 </div>
            </div>
        </div>
     </div>
</section>
   
<script>
    function clickAddToCart(productId) {
        $.ajax({
            url: '@Url.Action("AddToCart", "GioHang")',
            data: { productId: productId },
            success: function (response) {

                if (response.success) {

                    $.ajax({
                        url: '@Url.Action("RefreshCartViewComponent", "GioHang")',
                        success: function (response) {
                            $("#View_Cart").html(response);
                        },
                        error: function (xhr, ajaxOptions, thrownError) {
                            console.log(thrownError)
                            alert("Error updating Cart ViewComponent.");
                        }
                    });

                    const toast = $('#successToast');
                    toast.removeClass('d-none'); 

                    setTimeout(() => {
                        toast.addClass('d-none');
                    }, 2000);
                } else {
                    alert("Có lỗi xảy ra! Vui lòng thử lại.");
                }

            },
            error: function (xhr, ajaxOptions, thrownError) {
                alert(xhr.responseText);
            }
        });
    }
</script>

