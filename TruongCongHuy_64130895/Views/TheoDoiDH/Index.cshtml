@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<TruongCongHuy_64130895.Models.Order>
@{
    var existingReviews = ViewData["ExistingReviews"] as List<TruongCongHuy_64130895.Models.Review>;
}

<!-- Breadcrumb Start -->
<section class="breadcrumb breadcrumb_bg">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="breadcrumb_iner">
                    <div class="breadcrumb_iner_item">
                        <h2>Theo dõi đơn hàng</h2>
                        <p>Trang Chủ <span>-</span>Đơn hàng của bạn</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Breadcrumb End -->

<div style="background-color: #f5f5f5; ">
    <div class="container pt-4">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }

        @foreach (var order in Model)
        {
            <div class="mb-5 bg-white p-3" style="border-radius: 15px;">
                <h4>Đơn hàng ID: @order.Id</h4>
                <p>Trạng thái: <strong>@order.Status</strong></p>
                @{
                    var payment = order.Payments.FirstOrDefault(p => p.OrderId == order.Id);
                }
                <p>Phương thức thanh toán: <strong>@payment.PaymentMethod</strong></p>
                <p>Ngày đặt: @order.OrderDate.ToString("dd/MM/yyyy")</p>
                @if (order.Status == "Chờ xác nhận")
                {
                    <form asp-controller="TheoDoiDH" asp-action="CancelOrder" method="post" class="mb-3">
                        <input type="hidden" name="orderId" value="@order.Id" />
                        <button type="submit" class="btn btn-info">Hủy đơn</button>
                    </form>
                }
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Số lượng</th>
                            <th>Đơn giá</th>
                            <th>Tổng cộng</th>
                            @if (order.Status == "Đã giao")
                            {
                                <th>Đánh giá</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detail in order.OrderDetails)
                        {
                            <tr>
                                <td>
                                    <img src="/Admin-template/Images/SanPham/@detail.Product.ImageUrl"
                                         style="height: 100px; width: 200px; object-fit:contain" class="float-left" />
                                    <div>@detail.Product.Name</div>
                                </td>
                                <td>@detail.Quantity</td>
                                <td>@detail.UnitPrice.ToString("#,##0 VND")</td>
                                @{
                                    var total = detail.UnitPrice * detail.Quantity;
                                }
                                <td>@total.ToString("#,##0 VND")</td>
                          
                                @if (order.Status == "Đã giao")
                                {
                                    var reviewExists = existingReviews.Any(r => r.ProductId == detail.ProductId && r.OrderId == order.Id);
                                    <td>
                                        @if (reviewExists)
                                        {
                                            <span>Đã đánh giá</span>
                                        }
                                        else
                                        {
                                            <a class="btn btn-info"
                                               asp-controller="TheoDoiDH"
                                               asp-action="DanhGiaSP"
                                               asp-route-id="@detail.ProductId"
                                               asp-route-orderID="@order.Id">
                                                Đánh giá
                                            </a>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-right"><strong>Tổng tiền đơn hàng:</strong></td>
                            <td>
                                @order.OrderDetails.Sum(od => od.UnitPrice * od.Quantity).ToString("#,##0 VND")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
    <div class="flex-column align-items-center d-flex pb-4">
        @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new X.PagedList.Web.Common.PagedListRenderOptions
   {
       PageClasses = new[] { "page-link" },
       ClassToApplyToFirstListItemInPager = "page-item",
       ClassToApplyToLastListItemInPager = "page-item",
   })
    </div>
</div>

<style>
    .custom-pagination {
        margin-top: 20px;
    }

    .page-item {
        margin: 0 5px;
    }

    .page-link {
        color: lightskyblue;
        background-color: #fff;
    }

        .page-link:hover {
            background-color: lightskyblue;
            border-color: #ccc;
        }

    .page-item.active .page-link {
        border: none;
        background-color: lightskyblue;
        color: none;
    }

</style>
