                        },
                        {
                            elementType: 'labels.text.fill',
                            stylers: [{ color: '#ccdee9' }]
                        }
                    ];

                    // Tạo bản đồ
                    var map = new google.maps.Map(document.getElementById('map'), {
                        center: khanhHoa, // Đặt trung tâm bản đồ là Khánh Hòa
                        zoom: 9,
                        styles: grayStyles,
                        scrollwheel: false
                    });
                }
            </script>
