@model IEnumerable<TruongCongHuy_64130895.ViewModels.ProductVM>

<h3 class="mb-4 ms-2">Sản phẩm nổi bật</h3>

@foreach (var item in Model)
{
    <div class="d-flex justify-content-lg-start justify-content-center mb-2">
        <div class="rounded mr-2" style="width: 100px; height: 100px">
            <a asp-action="Details" asp-controller="SanPham" asp-route-id="@item.Id">
                <img src="/Admin-template/Images/SanPham/@item.Img" class="img-fluid rounded"
                     style="width: 100%; height: 100%;" />
            </a>
        </div>
        <div>
            <h6 class="mb-2">@item.Name</h6>
            <div class="d-flex flex-column mb-2">
                <div class="mb-2">
                    @for (int i = 0; i < item.Ratings; i++)
                    {
                        <i class="fas fa-star text-warning"></i>
                    }
                    @for (int i = item.Ratings; i < 5; i++)
                    {
                        <i class="far fa-star"></i>
                    }
                </div>
                <div>
                    @if (item.IsOnSale)
                    {
                        <h6 class="card-text"><del>@item.Price.ToString("#,##0 VND")</del></h6>
                        <h3 class="card-text text-info">@item.PriceSales.ToString("#,##0 VND")</h3>
                    }
                    else
                    {
                        <h3 class="card-text text-info">@item.Price.ToString("#,##0 VND")</h3>
                    }
                </div>
            </div>
        </div>
    </div>
}
<div class="d-flex justify-content-center m-4 ">
    <a asp-area="" asp-controller="SanPham" asp-action="Index" class="btn btn-info border border-info px-2 py-3 rounded-pill w-75">Xem thêm</a>
</div>