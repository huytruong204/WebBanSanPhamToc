@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common
@model IPagedList<TruongCongHuy_64130895.Models.Review>
@using Microsoft.AspNetCore.Identity;

@inject UserManager<Customers> userManager

<div class="px-3 mt-2">
    @if (TempData["RV"] != null)
    {
        <strong>@TempData["RV"]</strong>
    }
    else
    {
       <div class="row border border-3 bg-transparent  py-2">
            <div class="col-xl-4">
                <h4 class="mb-2">Đánh Giá Sản Phẩm</h4>
                <h2 class="text-danger font-weight-bold">@Model.Average(t=>t.Rating) trên 5</h2>
                <div>
                    @for (int i = 0; i < 5; i++)
                    {
                        <i class="fa fa-star text-danger"></i>
                    }
                </div>
                <p class="mt-1">Dựa trên <strong>@Model.Count() Đánh Giá</strong></p>
            </div>

            <!-- Filter Tabs -->
            <div class="col-xl-7">
                <button class="btn btn-info m-2">Tất Cả</button>
                <button class="btn btn-outline-info m-2">5 Sao (@Model.Count(t=>t.Rating==5))</button>
                <button class="btn btn-outline-info m-2">4 Sao (@Model.Count(t => t.Rating == 4))</button>
                <button class="btn btn-outline-info m-2">3 Sao (@Model.Count(t => t.Rating == 3))</button>
                <button class="btn btn-outline-info m-2">2 Sao (@Model.Count(t => t.Rating == 2))</button>
                <button class="btn btn-outline-info m-2">1 Sao (@Model.Count(t => t.Rating == 1))</button>
            </div>


       </div>

        <!-- Review Section -->
        <div class="row mt-5">
            <div class="col-lg-12">
                <h4 class="text-center mb-4">Đánh Giá Của Khách Hàng</h4>
                <div class="review-list">
                    @foreach (var review in Model)
                    {
                        var user = userManager.Users.FirstOrDefault(t => t.Id == review.UserId);
                        <div class="review-item border-bottom pb-3 mb-3">
                            <div class="media">
                                <div class="media-left mr-3">
                                    <img src="~/Image/Avatar/@user.avatar" alt="Ảnh người đánh giá" class="rounded-circle" style="width:75px; height:75px" />
                                </div>
                                <div class="media-body">
                                    <h5 class="mt-0">@user.UserName</h5>
                                    <i>@review.CreatedAt</i>
                                    <div class="stars mb-2">
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <i class="fas fa-star text-warning"></i>
                                        }
                                        @for (int i = review.Rating; i < 5; i++)
                                        {
                                            <i class="far fa-star"></i>
                                        }
                                    </div>
                                    <p>@review.Comment</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Pagination -->
<div class="d-flex justify-content-center mt-4">
    @Html.PagedListPager(Model, page => Url.Action("DanhGia", new { page }), new PagedListRenderOptions
    {
            LinkToFirstPageFormat = "<<",
            LinkToLastPageFormat = ">>",
        ClassToApplyToFirstListItemInPager = "page-item",
        ClassToApplyToLastListItemInPager = "page-item",
        PageClasses = new[] { "page-link" }
    })
</div>

<!-- Styles -->
<style>
    .stars i {
        font-size: 16px;
    }

    .filter-tabs button {
        margin: 0 5px;
    }
    .custom-pagination {
        margin-top: 20px;
    }

    .page-item {
        margin: 0 5px;
    }

    .page-link {
        background-color: #fff;
    }

        .page-link:hover {
            background-color: #f1f1f1;
            border-color: #ccc;
        }

    .page-item.active .page-link {
        border: none;
        background-color: lightskyblue;
        color: none;
    }

</style>
