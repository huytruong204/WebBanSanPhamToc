@model IEnumerable<TruongCongHuy_64130895.Models.MENU>
<div class="container bg-info">
    <div class="d-flex justify-content-between p-2">
        <div class="ps-2">
            <small class="me-3">
                <i class="fas fa-map-marker-alt me-2 text-secondary"></i>
                <a href="#" class="text-white">Nha Trang</a>
            </small>
            <small class="me-3">
                <i class="fas fa-envelope me-2 text-secondary"></i><a href="#" class="text-white">Email@Example.com</a>
            </small>
        </div>
        <div class="pe-2">
            @if (!@Context.User.Identity.IsAuthenticated)
            {
                <a asp-area="" asp-controller="KhachHang" asp-action="Login"
                   class="text-white"><small class="text-white mx-2">Đăng nhập</small>/</a>
                <a asp-area="" asp-controller="KhachHang" asp-action="Register"
                   class="text-white"><small class="text-white mx-2">Đăng ký</small></a>
            }
        </div>
    </div>
</div>
<header class="main_menu home_menu bg-white position-fixed ">
    <div class="container ">
        <div class="row align-items-center">
            <div class="col-lg-12">
                <nav class="navbar navbar-expand-lg navbar-light">
                    <a class="navbar-brand" asp-action="Index" asp-controller="Home"> <img class="rounded-circle" src="~/Image/logo2.webp" alt="logo" style="width: 70px;  height: 70px"> </a>
                    <button class="navbar-toggler" type="button" data-toggle="collapse"
                            data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="menu_icon"><i class="fas fa-bars"></i></span>
                    </button>
                    <div class="collapse navbar-collapse main-menu-item" id="navbarSupportedContent">
                        <ul class="navbar-nav">
                            @foreach (var menu in Model.Where(m => m.ParentId == null))
                            {


                                <li class="nav-item  @(Model.Any(m => m.ParentId == menu.Id) ? "dropdown" : "")">
                                    <a style="font-weight:700; font-size:15px;" class="nav-link px-3  @(Model.Any(m => m.ParentId == menu.Id) ? "dropdown-toggle" : "")"
                                       href="@menu.MenuUrl"
                                    @(Model.Any(m => m.ParentId == menu.Id) ? "id=\"navbarDropdown_" + menu.Id + "\" role=\"button\" data-toggle=\"dropdown\" aria-haspopup=\"true\" aria-expanded=\"false\"" : "")>
                                        @menu.Title
                                    </a>
                                    @if (Model.Any(m => m.ParentId == menu.Id)) 
                                    {
                                        <div class="dropdown-menu px-3" aria-labelledby="navbarDropdown_@menu.Id">
                                            @foreach (var subMenu in Model.Where(m => m.ParentId == menu.Id))
                                            {
                                                <a class="dropdown-item " href="@subMenu.MenuUrl">@subMenu.Title</a>
                                            }
                                        </div>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                    <!-- Header icons -->
                    <div class="header-icons d-flex align-items-center">
                        <!-- Search icon -->
                        <a id="search_1" href="javascript:void(0)" class="me-3"><i class="ti-search"></i></a>
                        <div id="View_Cart">
                            @await Component.InvokeAsync("Cart")
                        </div>
                        <partial name="_LoginPartial" />
                    </div>
                </nav>
            </div>
        </div>
    </div>
    <div class="search_input" id="search_input_box">
        <div class="container ">
            <form class="d-flex justify-content-between search-inner">
                <input type="text" class="form-control" id="search_input" placeholder="Search Here">
                <button type="submit" class="btn"></button>
                <span class="ti-close" id="close_search" title="Close Search"></span>
            </form>
        </div>
    </div>
</header>


<style>
    .container.bg-info {
        transition: transform 0.3s ease-in-out;
        top: 0;
        border-radius: 0 0 15px 15px;
        width: 100%;
        z-index: 999;
    }

    header.main_menu {
        top: 37px;
        width: 100%;
        z-index: 998;
        transition: top 0.3s ease-in-out;
    }

        header.main_menu.shrink {
            top: 0; 
        }
</style>
<script>
    $(document).ready(function () {
        let lastScrollTop = 0;
        const headerInfo = $('.container.bg-info');
        const mainMenu = $('header.main_menu');
        let isHidden = false;

        $(window).on('scroll', function () {
            const currentScroll = $(this).scrollTop();

            if (currentScroll > 50) {
                // Cuộn xuống -> Ẩn header info
                if (!isHidden) {
                    headerInfo.css('transform', 'translateY(-100%)');
                    mainMenu.addClass('shrink'); // Đưa menu lên
                    isHidden = true;
                }
            } else if (currentScroll === 0) {
                // Cuộn lên đầu trang -> Hiển thị lại header info
                if (isHidden) {
                    headerInfo.css('transform', 'translateY(0)');
                    mainMenu.removeClass('shrink'); // Trả menu về vị trí ban đầu
                    isHidden = false;
                }
            }

            lastScrollTop = currentScroll <= 0 ? 0 : currentScroll; // Không cho giá trị âm
        });
    });


</script>

